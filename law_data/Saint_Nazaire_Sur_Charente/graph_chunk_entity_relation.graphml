<node id="&quot;SUPPRESSION DU CICE&quot;">
  <data key="d0">"PROPOSITION"</data>
  <data key="d1">"Proposal to abolish the CICE tax credit mechanism, arguing its ineffectiveness in job creation and economic growth."&lt;SEP&gt;"The proposal for the abolition of the CICE, arguing it does not create jobs as intended."</data>
  <data key="d2">contrib-64af714a13f88ba6b8a5c2d30baf3301</data>
  <data key="d3">"SUPPRESSION DU CICE"</data>
