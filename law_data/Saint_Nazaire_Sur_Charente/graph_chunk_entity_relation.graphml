<node id="&quot;IMPOSITION DE TOTAL&quot;">
  <data key="d0">"PROPOSITION"</data>
  <data key="d1">"The call for Total, a multinational company, to be taxed appropriately acknowledges the need for corporate responsibility."&lt;SEP&gt;"The call for the taxation of the Total company and all multinational corporations operating in France."</data>
  <data key="d2">contrib-64af714a13f88ba6b8a5c2d30baf3301</data>
  <data key="d3">"IMPOSITION DE TOTAL"</data>
