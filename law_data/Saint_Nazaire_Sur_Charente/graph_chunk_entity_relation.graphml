  <data key="d2">contrib-64af714a13f88ba6b8a5c2d30baf3301</data>
  <data key="d3">"AUGMENTATION DU SMIC"</data>
</node>
<node id="&quot;AUGMENTATION DU TAUX D'IMPOSITION&quot;">
  <data key="d0">"PROPOSITION"</data>
  <data key="d1">"The proposal suggests raising the corporate tax rates that were lowered in 2018, to ensure fair contribution to public finances."</data>
  <data key="d2">contrib-64af714a13f88ba6b8a5c2d30baf3301</data>
  <data key="d3">"AUGMENTATION DU TAUX D'IMPOSITION"</data>
