<node id="&quot;SUPPRESSION DES HEURES SUPPLÉMENTAIRES DÉFISCALISÉES&quot;">
  <data key="d0">"PROPOSITION"</data>
  <data key="d1">"Proposal to eliminate tax-exempt overtime, as it allegedly does not contribute to retirement or hiring."</data>
  <data key="d2">contrib-64af714a13f88ba6b8a5c2d30baf3301</data>
  <data key="d3">"SUPPRESSION DES HEURES SUPPLÉMENTAIRES DÉFISCALISÉES"</data>
