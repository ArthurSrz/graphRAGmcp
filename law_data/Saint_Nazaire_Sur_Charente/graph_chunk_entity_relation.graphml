<node id="&quot;RÉTABLISSEMENT DE L'ISF&quot;">
  <data key="d0">"PROPOSITION"</data>
  <data key="d1">"The proposal advocates for the reinstatement of the wealth tax (ISF) that was previously removed by President Macron."</data>
  <data key="d2">contrib-64af714a13f88ba6b8a5c2d30baf3301</data>
  <data key="d3">"RÉTABLISSEMENT DE L'ISF"</data>
