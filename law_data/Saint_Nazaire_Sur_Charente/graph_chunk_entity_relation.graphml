<node id="&quot;PAS DE LOBBYISTE OU EX-LOBBYISTE&quot;">
  <data key="d0">"PROPOSITION"</data>
  <data key="d1">"Proposal to ban lobbyists or former lobbyists from holding electoral office to reduce corruption."&lt;SEP&gt;"Proposal to prohibit lobbyists and former lobbyists from serving in government roles to limit corruption risks."</data>
  <data key="d2">contrib-64af714a13f88ba6b8a5c2d30baf3301</data>
