  <data key="d8">1</data>
  <data key="d9">RELATED_TO</data>
</edge>
<edge source="&quot;CICE&quot;" target="&quot;DISCRIMINATION FISCALE&quot;">
  <data key="d5">6.0</data>
  <data key="d6">"The CICE is criticized for contributing to tax discrimination against lower-income individuals, affecting fairness in the tax system."</data>
  <data key="d7">contrib-e5637c5257ccf7da22163a78a1b7f116</data>
  <data key="d8">1</data>
  <data key="d9">RELATED_TO</data>
