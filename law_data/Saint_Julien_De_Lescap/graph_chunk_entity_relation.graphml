<graph edgedefault="undirected"><node id="&quot;CAHIER DE SAINT-JULIEN-DE-L'ESCAP&quot;">
  <data key="d0">"CONTRIBUTION"</data>
  <data key="d1">"Cahier de Saint-Julien-de-l'Escap is a citizen contribution document detailing various opinions and proposals from the citizens of Saint-Julien-de-l'Escap."</data>
